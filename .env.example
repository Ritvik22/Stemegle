# Public origin used for secure cookies, CSRF checks, and realtime origins.
BETTER_AUTH_URL=https://stemegle.com
# Exact comma-separated extra origins accepted by auth and realtime.
APP_ALLOWED_ORIGINS=https://www.stemegle.com

# PostgreSQL stays private to the Compose network. Use URL-safe hex for the
# password because Compose embeds it in the internal DATABASE_URL.
POSTGRES_DB=stemegle
POSTGRES_USER=stemegle_admin
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=
# Independent runtime-role password; the API never receives the admin password.
APP_DATABASE_PASSWORD=
DATABASE_POOL_SIZE=12

# Server-only secrets. Generate each independently with: openssl rand -hex 32
BETTER_AUTH_SECRET=
ANALYTICS_COOKIE_SECRET=

ANALYTICS_RETENTION_DAYS=400

# Web, API, and PostgreSQL ports bind only to loopback. Override all three when
# running an isolated staging project on the same host.
STEMEGLE_IMAGE_PREFIX=stemegle
STEMEGLE_PORT=8097
STEMEGLE_BACKEND_PORT=8787
POSTGRES_PORT=5432

# A backup runs immediately and then daily. Every archive is checksummed and
# restored into a scratch database before it is marked successful.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETRY_SECONDS=900
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_SECONDS=172800
BACKUP_VERIFY_DATABASE=stemegle_backup_verify

# GitHub webhook deployment (only required with the autodeploy profile).
DEPLOY_REPO=ritvik22/stemegle
DEPLOY_BRANCH=main
GITHUB_WEBHOOK_SECRET=
