# Public browser config. These are baked into the Vite build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SITE_URL=https://stemegle.com
STEMEGLE_PORT=8097
STEMEGLE_ANALYTICS_PORT=8098
# Server-only. Never prefix this key with VITE_ or commit its value.
SUPABASE_SERVICE_ROLE_KEY=
# Generate with: openssl rand -hex 32
ANALYTICS_COOKIE_SECRET=
DEPLOY_REPO=ritvik22/stemegle
DEPLOY_BRANCH=main
GITHUB_WEBHOOK_SECRET=

# Optional compatibility with the previous Vercel/Next-style names.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required by automated database migrations. Prefer the non-pooling URL.
POSTGRES_URL_NON_POOLING=
# POSTGRES_URL=
